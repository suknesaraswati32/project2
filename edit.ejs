<!DOCTYPE html>
<html lang="en">
<head>
    <title>Edit Task</title>
</head>
<body>

    <h2>Update Task</h2>

    <form action="/task/<%= task.id %>?_method=PUT" method="POST">

        <input type="text" name="title" value="<%= task.title %>" placeholder="Title">
        <br><br>

        <textarea name="description"><%= task.description %></textarea>
        <br><br>

        <input type="text" name="status" value="<%= task.status %>" placeholder="Status">
        <br><br>

        <input type="text" name="priority" value="<%= task.priority %>" placeholder="Priority">
        <br><br>

        <input type="date" name="deadline" value="<%= task.deadline %>">
        <br><br>

        <input type="text" name="subject" value="<%= task.subject %>" placeholder="Subject">
        <br><br>

        <button>Update Task</button>

    </form>

</body>
</html>